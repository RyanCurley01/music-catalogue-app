<h2>Edit Existing Music</h2>

<%= form_with(model: @music, url: music_path(@music), method: :patch, local: true, scope: :music) do |f| %>
  <div class="mb-3">
    <%= f.label :title, 'Title', class: 'col-form-label' %>
    <%= f.text_field :title, class: 'form-control' %>
  </div>

  <br>

  <div class="mb-3">
    <%= f.label :artist, 'Artist', class: 'col-form-label' %>
    <%= f.text_field :artist, class: 'form-control' %>
  </div>
  
  <br>

  <div class="mb-3">
    <%= f.label :album, 'Album', class: 'col-form-label' %>
    <%= f.text_field :album, class: 'form-control' %>
  </div>
  
  <br>

  <div class="mb-3">
    <%= f.label :genre, 'Genre', class: 'col-form-label' %>
    <%= f.text_field :genre, class: 'form-control' %>
  </div>
  
  <br>

  <div class="mb-3">
    <%= f.label :release_date, 'Released On', class: 'col-form-label' %>
    <%= f.text_field :release_date, class: 'form-control' %>
  </div>

  <br>

  <div class="mb-3">
    <%= f.label :rating, 'Rating', class: 'col-form-label' %>
    <%= f.number_field :rating, class: 'form-control' %>
  </div>
  
  <br>

  <div class="mb-3">
    <%= f.submit 'Update Music Info', class: 'btn btn-primary' %>
    <%= link_to 'Cancel', music_path(@music), class: 'btn btn-secondary' %>
  </div>

  <br>

  <%= link_to 'Back To Home', music_index_path, class: 'btn btn-secondary' %>
<% end %>
